# GalacticBoard environment template. Copy to `.env` and fill in.

# ── Database ──────────────────────────────────────────────────────────────
# SQLite (default, self-host). Relative paths resolve against prisma/, so this
# lands at <project root>/data/app.db. For Postgres: switch the datasource
# provider in prisma/schema.prisma and use a postgres:// URL here.
DATABASE_URL="file:../data/app.db"

# ── Auth (Phase 2) ────────────────────────────────────────────────────────
# Auth.js v5. Generate with: openssl rand -base64 32
# AUTH_SECRET=""
# Stable across rebuilds, or Server Actions break after redeploy:
# NEXT_SERVER_ACTIONS_ENCRYPTION_KEY=""

# Instance admin(s): comma-separated emails. Source of truth for isInstanceAdmin.
# ADMIN_EMAILS="you@example.com"

# OAuth providers — a provider is enabled only if its keys are present.
# AUTH_GITHUB_ID=""
# AUTH_GITHUB_SECRET=""
# AUTH_GITLAB_ID=""
# AUTH_GITLAB_SECRET=""
# Set to make the instance OAuth-only (hides email/password sign-in + sign-up). Ignored unless at least
# one OAuth provider above is configured, so you can't lock yourself out.
# AUTH_PASSWORD_DISABLED="true"

# ── Scale / abuse (Phase 6+) ──────────────────────────────────────────────
# Number of trusted reverse-proxy hops for X-Forwarded-For parsing (0 = ignore XFF).
# TRUSTED_PROXY_HOPS="1"
# Salt for suggestion ipHash (abuse correlation, not anonymizing).
# SUGGESTION_IP_SALT=""
# Optional Cloudflare Turnstile (anonymous suggestion challenge).
# TURNSTILE_SITE_KEY=""
# TURNSTILE_SECRET_KEY=""

# ── In-app AI (Phase: AI parity) ──────────────────────────────────────────
# Optional. If unset, all AI features (generate map / expand node / summarize)
# are hidden — the app works fully without it. Get a key at console.anthropic.com.
# ANTHROPIC_API_KEY=""
# Model override. Default is the most capable Claude; set claude-sonnet-4-6 for
# faster/cheaper interactive generation.
# AI_MODEL="claude-opus-4-8"

# ── Public REST API + MCP server (Phase 8, feature #14) ───────────────────
# No env needed: mint scoped tokens in-app at /settings/tokens, then use them as
# `Authorization: Bearer gbk_…` against /api/v1 or via mcp-server/ (see its README).

# ── Real-time collaboration (Phase 7) ─────────────────────────────────────
# OFF by default — the editor is fully single-user without this. To enable live
# multiplayer (presence cursors + co-editing): run the collab server
#   COLLAB_PORT=1234 node collab-server/index.mjs
# and point the app at it (public — inlined into the client bundle):
# NEXT_PUBLIC_COLLAB_URL="ws://localhost:1234"
